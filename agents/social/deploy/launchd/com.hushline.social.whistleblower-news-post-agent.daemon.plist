<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hushline.social.whistleblower-news-post-agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>__REPO_DIR__/agents/social/scripts/run_whistleblower_news_post_agent_launchd.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__REPO_DIR__</string>

  <key>UserName</key>
  <string>__USER_NAME__</string>

  <key>GroupName</key>
  <string>__GROUP_NAME__</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>__HOME_DIR__</string>
    <key>HUSHLINE_SOCIAL_ENV_FILE</key>
    <string>__ENV_FILE__</string>
    <key>HUSHLINE_SOCIAL_REPO_DIR</key>
    <string>__SOCIAL_REPO_DIR__</string>
    <key>HUSHLINE_SOCIAL_COMBINED_LOG_FILE</key>
    <string>__REPO_DIR__/logs/social/social-daily.log</string>
    <key>HUSHLINE_SOCIAL_LAUNCHD_SCOPE</key>
    <string>daemon</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>ProcessType</key>
  <string>Background</string>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>4</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__REPO_DIR__/logs/social/whistleblower-news-post-agent.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>__REPO_DIR__/logs/social/whistleblower-news-post-agent.stderr.log</string>
</dict>
</plist>
